digraph {

    graph [
        label="lms",
        labelloc=t,

        pad=0.4,

        // Consider rendering the graph using a different layout algorithm, such as:
        // [dot, neato, twopi, circo, fdp, sfdp]
        layout=neato,
        overlap=false,
        splines="line",
        rankdir=LR,

        fontname="Helvetica", 
        fontsize="36",
    ];

    node [
        fontname="monospace",
        fontsize="10",
        shape="record",
        style="filled",
    ];

    edge [
        fontname="monospace",
        fontsize="10",
    ];

    "lms" [label="crate|lms", fillcolor="#5397c8"]; // "crate" node
    "a::la" [label="pub mod|a::la", fillcolor="#81c169"]; // "mod" node
    "a::la::m" [label="pub mod|a::la::m", fillcolor="#81c169"]; // "mod" node
